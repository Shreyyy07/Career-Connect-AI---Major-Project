# ── Database ────────────────────────────────────────────────────────────────────
# For local dev: use SQLite (no setup needed)
# DATABASE_URL=sqlite+pysqlite:///./career_connect_ai.db
# For production: use Neon PostgreSQL (or any Postgres)
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ── Auth ─────────────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ── CORS (comma-separated) ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:8085

# ── GitHub AI Inference ──────────────────────────────────────────────────────────
# Get a token from: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_AI_ENDPOINT=https://models.github.ai/inference
GITHUB_AI_MODEL=openai/gpt-4.1

# ── Gemini (optional fallback) ───────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Email (Gmail SMTP) ───────────────────────────────────────────────────────────
# Use a Gmail App Password (not your real Gmail password)
# Guide: https://support.google.com/accounts/answer/185833
SMTP_EMAIL=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password-here

# ── n8n Voice Agent (optional) ───────────────────────────────────────────────────
N8N_WEBHOOK_URL=
